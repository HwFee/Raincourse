# ------------------------------
# Python cache and artifacts
# ------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ------------------------------
# Virtual environments
# ------------------------------
venv/
.venv/
env/

# ------------------------------
# Build outputs
# ------------------------------
dist/
build/

# ------------------------------
# IDE and editor files
# ------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------
# Logs and temp files
# ------------------------------
logs/
*.log
*.tmp
*.bak
*.cache

# ------------------------------
# Local environment variables
# ------------------------------
.env
.env.*
!.env.example

# ------------------------------
# Local runtime data (privacy)
# ------------------------------
user/*.json
!user/.gitkeep

answer/*.json
!answer/.gitkeep

exports/*
!exports/.gitkeep

config/api_configs.json

# ------------------------------
# PyInstaller
# ------------------------------
*.manifest
*.spec.backup

# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
